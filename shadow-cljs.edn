{:source-paths ["src"]
 :dependencies [[reagent/reagent "1.2.0"]
                [re-frame/re-frame "1.4.0"]
                [datascript/datascript "1.6.3"]]
 :dev-http {3000 "public"}
 :builds {:app {:target :browser
                :output-dir "public/js"
                :asset-path "js"
                :modules {:main {:init-fn animated-storefront.core/init}}
                :dev  {:closure-defines {animated-storefront.config/api-key  #shadow/env "ANTHROPIC_API_KEY"
                                         animated-storefront.config/dev-mode true}}
                :release {:closure-defines {animated-storefront.config/dev-mode false
                                            animated-storefront.config/proxy-url #shadow/env "CHAT_API_URL"}}}}}
